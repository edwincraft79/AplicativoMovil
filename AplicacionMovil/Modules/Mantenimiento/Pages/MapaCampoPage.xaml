<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AplicacionMovil.Modules.Mantenimiento.Pages.MapaCampoPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title=""
    BackgroundColor="#F5F3FF">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ══ BARRA SUPERIOR ══════════════════════════════════════════════ -->
        <Frame Grid.Row="0" Padding="0" CornerRadius="0"
               BorderColor="Transparent" BackgroundColor="White" HasShadow="True">
            <Grid RowDefinitions="Auto,Auto" Padding="14,10,14,10">

                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                    <VerticalStackLayout Grid.Column="0" Spacing="1">
                        <Label Text="🗺️ Mapa de Campo"
                               FontSize="16" FontAttributes="Bold" TextColor="#0F172A" />
                        <Label x:Name="lblOtInfo"
                               Text="Cargando..." FontSize="11" TextColor="#64748B" />
                    </VerticalStackLayout>
                    <Frame Grid.Column="1" Padding="8,4" CornerRadius="8"
                           BorderColor="Transparent" BackgroundColor="#EDE9FE" HasShadow="False">
                        <Label x:Name="lblContador"
                               Text="0/0 pts" FontSize="11" FontAttributes="Bold" TextColor="#4C1D95" />
                    </Frame>
                </Grid>

                <Grid Grid.Row="1" ColumnDefinitions="*,*,*" ColumnSpacing="8">
                    <Button Grid.Column="0" Text="← Volver"
                            FontSize="12" FontAttributes="Bold" TextColor="White"
                            BackgroundColor="#64748B" CornerRadius="10" HeightRequest="34"
                            Clicked="OnVolverClicked" />
                    <Button Grid.Column="1" Text="🔄 Actualizar"
                            FontSize="12" FontAttributes="Bold" TextColor="White"
                            BackgroundColor="#7C3AED" CornerRadius="10" HeightRequest="34"
                            Clicked="OnActualizarClicked" />
                    <Button Grid.Column="2" Text="📋 Lista"
                            FontSize="12" FontAttributes="Bold" TextColor="White"
                            BackgroundColor="#0EA5E9" CornerRadius="10" HeightRequest="34"
                            Clicked="OnListaClicked" />
                </Grid>
            </Grid>
        </Frame>

        <!-- ══ MAPA LEAFLET (WebView) ═══════════════════════════════════════ -->
        <WebView Grid.Row="1"
                 x:Name="mapaWebView"
                 Navigating="OnMapaNavigating" />

        <!-- ══ PANEL FEATURE SELECCIONADO ══════════════════════════════════ -->
        <Frame Grid.Row="2"
               x:Name="panelFeature"
               IsVisible="False"
               Padding="14,12" CornerRadius="0"
               BorderColor="#DDD6FE" BackgroundColor="White" HasShadow="True">
            <VerticalStackLayout Spacing="8">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label x:Name="lblFeatureNombre"
                               FontSize="14" FontAttributes="Bold" TextColor="#0F172A" />
                        <Label x:Name="lblFeatureTipo"
                               FontSize="11" TextColor="#64748B" />
                    </VerticalStackLayout>
                    <Frame Grid.Column="1" Padding="6,3" CornerRadius="8"
                           BorderColor="Transparent" HasShadow="False"
                           x:Name="frameEstadoFeature">
                        <Label x:Name="lblEstadoFeature"
                               FontSize="11" FontAttributes="Bold" />
                    </Frame>
                </Grid>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Button Grid.Column="0"
                            Text="✏️ Registrar Ítems"
                            FontSize="13" FontAttributes="Bold"
                            TextColor="White" BackgroundColor="#7C3AED"
                            CornerRadius="10" HeightRequest="42"
                            Clicked="OnRegistrarItemsClicked" />
                    <Button Grid.Column="1"
                            Text="✕ Cerrar"
                            FontSize="13"
                            TextColor="#64748B" BackgroundColor="#F1F5F9"
                            CornerRadius="10" HeightRequest="42"
                            Clicked="OnCerrarPanelClicked" />
                </Grid>
            </VerticalStackLayout>
        </Frame>

    </Grid>
</ContentPage>
