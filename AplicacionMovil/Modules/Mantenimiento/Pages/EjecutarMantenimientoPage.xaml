<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AplicacionMovil.Modules.Mantenimiento.Pages.EjecutarMantenimientoPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title=""
    BackgroundColor="#F5F3FF">

    <ContentPage.Resources>
        <Style TargetType="Button" x:Key="HeaderButton">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextColor" Value="White" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontAttributes" Value="Bold" />
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- ══ BARRA SUPERIOR ══════════════════════════════════════════ -->
        <Frame Grid.Row="0"
               Padding="0" CornerRadius="20"
               BorderColor="Transparent" HasShadow="True" BackgroundColor="White">
            <Grid RowDefinitions="Auto,Auto,Auto" Padding="16,12,16,14">

                <BoxView Grid.Row="0"
                         BackgroundColor="#7C3AED" HeightRequest="3"
                         CornerRadius="2" Margin="0,0,0,10" />

                <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,0,0,10">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label Text="▶ Ejecutar Mantenimiento"
                               FontSize="17" FontAttributes="Bold" TextColor="#0F172A" />
                        <Label x:Name="lblSubtitulo"
                               Text="Cargando..." FontSize="11" TextColor="#64748B" />
                    </VerticalStackLayout>
                    <Frame Grid.Column="1"
                           Padding="8,4" CornerRadius="8"
                           BorderColor="Transparent" BackgroundColor="#EDE9FE" HasShadow="False">
                        <Label x:Name="lblTipo"
                               Text="PREVENTIVO"
                               FontSize="11" FontAttributes="Bold" TextColor="#4C1D95" />
                    </Frame>
                </Grid>

                <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Button Grid.Column="0"
                            Text="← Volver"
                            Style="{StaticResource HeaderButton}"
                            BackgroundColor="#64748B" HeightRequest="36"
                            Clicked="OnVolverClicked" />
                    <Button Grid.Column="1"
                            x:Name="btnGps"
                            Text="🗺️ Ver mapa"
                            Style="{StaticResource HeaderButton}"
                            BackgroundColor="#0EA5E9" HeightRequest="36"
                            Clicked="OnObtenerGpsClicked" />
                </Grid>
            </Grid>
        </Frame>

        <!-- ══ FORMULARIO ═════════════════════════════════════════════ -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16,12" Spacing="12">

                <!-- Datos del trabajo (solo lectura) -->
                <Frame Padding="14,12" CornerRadius="14"
                       BorderColor="#DDD6FE" BackgroundColor="White" HasShadow="False">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="📋 Datos del Trabajo"
                               FontSize="13" FontAttributes="Bold" TextColor="#4C1D95" />

                        <Grid ColumnDefinitions="Auto,*"
                              RowDefinitions="Auto,Auto,Auto"
                              ColumnSpacing="10" RowSpacing="5">

                            <Label Grid.Row="0" Grid.Column="0" Text="Nombre:"
                                   FontSize="12" FontAttributes="Bold" TextColor="#64748B" />
                            <Label Grid.Row="0" Grid.Column="1" x:Name="lblNombre"
                                   FontSize="12" TextColor="#0F172A" LineBreakMode="WordWrap" />

                            <Label Grid.Row="1" Grid.Column="0" Text="Ubicación:"
                                   FontSize="12" FontAttributes="Bold" TextColor="#64748B" />
                            <Label Grid.Row="1" Grid.Column="1" x:Name="lblReferenciaUbicacion"
                                   FontSize="12" TextColor="#0F172A" LineBreakMode="TailTruncation" />

                            <Label Grid.Row="2" Grid.Column="0" Text="Problema:"
                                   FontSize="12" FontAttributes="Bold" TextColor="#64748B" />
                            <Label Grid.Row="2" Grid.Column="1" x:Name="lblDefinicionProblema"
                                   FontSize="12" TextColor="#475569" LineBreakMode="WordWrap" />
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <!-- GPS -->
                <Frame Padding="14,12" CornerRadius="14"
                       BorderColor="#DDD6FE" BackgroundColor="White" HasShadow="False">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="📍 GPS en Campo"
                               FontSize="13" FontAttributes="Bold" TextColor="#4C1D95" />
                        <Label x:Name="lblGps"
                               Text="Presiona 'Ver mapa' para ubicar el punto sobre la red GIS"
                               FontSize="12" TextColor="#64748B"
                               HorizontalTextAlignment="Center" />
                        <Label x:Name="lblPrecision"
                               Text="" FontSize="12" TextColor="#64748B"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Resultado -->
                <Frame Padding="14,12" CornerRadius="14"
                       BorderColor="#DDD6FE" BackgroundColor="White" HasShadow="False">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="✅ Resultado del Trabajo"
                               FontSize="13" FontAttributes="Bold" TextColor="#4C1D95" />
                        <Picker x:Name="pkrResultado"
                                Title="Seleccione resultado"
                                FontSize="13" TextColor="#0F172A">
                            <Picker.Items>
                                <x:String>Completado</x:String>
                                <x:String>Completado parcialmente</x:String>
                                <x:String>No se pudo ejecutar</x:String>
                                <x:String>Requiere reprogramación</x:String>
                            </Picker.Items>
                        </Picker>
                    </VerticalStackLayout>
                </Frame>

                <!-- Observaciones -->
                <Frame Padding="14,12" CornerRadius="14"
                       BorderColor="#DDD6FE" BackgroundColor="White" HasShadow="False">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="📝 Observaciones / Trabajo Realizado"
                               FontSize="13" FontAttributes="Bold" TextColor="#4C1D95" />
                        <Editor x:Name="txtObservaciones"
                                Placeholder="Describe el trabajo realizado, materiales usados, hallazgos..."
                                FontSize="13" TextColor="#0F172A"
                                HeightRequest="110" BackgroundColor="#F5F3FF" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Fotos -->
                <Frame Padding="14,12" CornerRadius="14"
                       BorderColor="#DDD6FE" BackgroundColor="White" HasShadow="False">
                    <VerticalStackLayout Spacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0"
                                   Text="📷 Fotos (máx. 5)"
                                   FontSize="13" FontAttributes="Bold" TextColor="#4C1D95" />
                            <Label Grid.Column="1"
                                   x:Name="lblContadorFotos"
                                   Text="0/5" FontSize="12" TextColor="#64748B" />
                        </Grid>

                        <Button Text="📷 Tomar Foto"
                                FontSize="13" FontAttributes="Bold"
                                TextColor="White" BackgroundColor="#0EA5E9"
                                CornerRadius="10" HeightRequest="40"
                                Clicked="OnTomarFotoClicked" />

                        <FlexLayout x:Name="flxFotos"
                                    Wrap="Wrap" Direction="Row"
                                    JustifyContent="Start" AlignItems="Start" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Botón Enviar -->
                <Frame Padding="0" CornerRadius="14"
                       BorderColor="Transparent" BackgroundColor="#7C3AED" HasShadow="True">
                    <Button x:Name="btnEnviar"
                            Text="🔧 Enviar Ejecución"
                            FontSize="15" FontAttributes="Bold"
                            TextColor="White" BackgroundColor="Transparent"
                            HeightRequest="52"
                            Clicked="OnEnviarClicked" />
                </Frame>

                <ActivityIndicator x:Name="actIndicator"
                                   IsRunning="False" IsVisible="False"
                                   Color="#7C3AED" HorizontalOptions="Center" />

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
