<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AplicacionMovil.Modules.Deficiencias.Pages.MisDeficienciasPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title=""
    BackgroundColor="#F0FDF4">

    <ContentPage.Resources>

        <Style TargetType="Button" x:Key="HeaderButton">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextColor" Value="White" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="HeightRequest" Value="34" />
        </Style>

        <Style TargetType="Label" x:Key="ReadKey">
            <Setter Property="FontSize" Value="9" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="TextColor" Value="#6B7280" />
            <Setter Property="TextTransform" Value="Uppercase" />
            <Setter Property="CharacterSpacing" Value="0.6" />
        </Style>

    </ContentPage.Resources>

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsEnabled="False" IsVisible="False" />
    </Shell.BackButtonBehavior>

    <Grid RowDefinitions="Auto,*">

        <!-- ══════════════════════════════════════
             HEADER VERDE
        ══════════════════════════════════════ -->
        <Frame Grid.Row="0"
               Padding="0"
               CornerRadius="22"
               BorderColor="Transparent"
               HasShadow="True"
               BackgroundColor="#166534">

            <Grid RowDefinitions="Auto,Auto" Padding="16,14,16,16" RowSpacing="12">

                <!-- Título + Contador -->
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label Text="MIS DEFICIENCIAS"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#86EFAC"
                               CharacterSpacing="1" />
                        <Label Text="Listado de deficiencias asignadas"
                               FontSize="11"
                               TextColor="#BBF7D0" />
                    </VerticalStackLayout>

                    <Frame Grid.Column="1"
                           Padding="12,6"
                           CornerRadius="20"
                           BorderColor="Transparent"
                           BackgroundColor="#15803D"
                           HasShadow="False"
                           VerticalOptions="Center">
                        <Label x:Name="lblContadorDeficiencias"
                               Text="— Def."
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="White" />
                    </Frame>
                </Grid>

                <!-- Botones de navegación -->
                <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                    <Button Grid.Column="0"
                            Text="🏠 Inicio"
                            Style="{StaticResource HeaderButton}"
                            BackgroundColor="#15803D"
                            Clicked="OnVolverInicioClicked" />
                    <Button Grid.Column="1"
                            Text="🗺️ Mapa"
                            Style="{StaticResource HeaderButton}"
                            BackgroundColor="#0284C7"
                            Clicked="OnVerMapa" />
                    <Button Grid.Column="2"
                            Text="📋 Historial"
                            Style="{StaticResource HeaderButton}"
                            BackgroundColor="#0369A1"
                            Clicked="OnHistorialClicked" />
                    <Button Grid.Column="3"
                            Text="🚪 Salir"
                            Style="{StaticResource HeaderButton}"
                            BackgroundColor="#DC2626"
                            Clicked="OnLogoutClicked" />
                </Grid>
            </Grid>
        </Frame>

        <!-- ══════════════════════════════════════
             LISTA DE DEFICIENCIAS
        ══════════════════════════════════════ -->
        <RefreshView Grid.Row="1"
                     x:Name="refreshView"
                     RefreshColor="#16A34A"
                     Refreshing="OnRefresh">

            <ScrollView Padding="14,16,14,20">
                <VerticalStackLayout Spacing="16"
                                     BindableLayout.ItemsSource="{Binding Deficiencias}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>

                            <!-- ╔══════════════════════════════╗
                                 ║  TARJETA DE DEFICIENCIA      ║
                                 ╚══════════════════════════════╝ -->
                            <Frame Padding="0"
                                   CornerRadius="16"
                                   HasShadow="True"
                                   BorderColor="Transparent"
                                   BackgroundColor="White">

                                <VerticalStackLayout Spacing="0">

                                    <!-- ── CABECERA: Código + Estado ── -->
                                    <Grid ColumnDefinitions="*,Auto"
                                          Padding="14,12,14,10">

                                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                                            <Label Text="DEFICIENCIA"
                                                   FontSize="9"
                                                   FontAttributes="Bold"
                                                   TextColor="#9CA3AF"
                                                   CharacterSpacing="1" />
                                            <Label Text="{Binding CodigoDeficiencia}"
                                                   FontSize="18"
                                                   FontAttributes="Bold"
                                                   TextColor="#166534" />
                                        </VerticalStackLayout>

                                        <!-- Badge Estado -->
                                        <Frame Grid.Column="1"
                                               Padding="10,5"
                                               CornerRadius="20"
                                               BorderColor="Transparent"
                                               BackgroundColor="#DCFCE7"
                                               HasShadow="False"
                                               VerticalOptions="Center">
                                            <Label Text="{Binding EstadoSubsanacion}"
                                                   FontSize="11"
                                                   FontAttributes="Bold"
                                                   TextColor="#166534" />
                                        </Frame>
                                    </Grid>

                                    <!-- Badge Prioridad -->
                                    <Frame Padding="8,4"
                                           Margin="14,0,14,10"
                                           CornerRadius="8"
                                           BorderColor="Transparent"
                                           BackgroundColor="#FEE2E2"
                                           HasShadow="False"
                                           HorizontalOptions="Start">
                                        <Label FontSize="11"
                                               FontAttributes="Bold"
                                               TextColor="#DC2626">
                                            <Label.Text>
                                                <MultiBinding StringFormat="⚠️ Prioridad: {0}">
                                                    <Binding Path="Prioridad" />
                                                </MultiBinding>
                                            </Label.Text>
                                        </Label>
                                    </Frame>

                                    <!-- Divisor -->
                                    <BoxView HeightRequest="1"
                                             BackgroundColor="#E5E7EB"
                                             Margin="14,0" />

                                    <!-- ── CUADRANTE DE DATOS ── -->
                                    <Grid RowDefinitions="Auto,Auto"
                                          ColumnDefinitions="*,*"
                                          Padding="14,12,14,4"
                                          RowSpacing="0"
                                          ColumnSpacing="0">

                                        <!-- [0,0] Zonal -->
                                        <Frame Grid.Row="0" Grid.Column="0"
                                               Padding="10,8"
                                               Margin="0,0,4,8"
                                               CornerRadius="10"
                                               BackgroundColor="#F0FDF4"
                                               BorderColor="#86EFAC"
                                               HasShadow="False">
                                            <VerticalStackLayout Spacing="3">
                                                <Label Text="📍 ZONAL"
                                                       Style="{StaticResource ReadKey}"
                                                       TextColor="#15803D" />
                                                <Label Text="{Binding UnidadZonal}"
                                                       FontSize="12"
                                                       FontAttributes="Bold"
                                                       TextColor="#14532D" />
                                            </VerticalStackLayout>
                                        </Frame>

                                        <!-- [0,1] Alimentador -->
                                        <Frame Grid.Row="0" Grid.Column="1"
                                               Padding="10,8"
                                               Margin="4,0,0,8"
                                               CornerRadius="10"
                                               BackgroundColor="#F0F9FF"
                                               BorderColor="#7DD3FC"
                                               HasShadow="False">
                                            <VerticalStackLayout Spacing="3">
                                                <Label Text="⚡ ALIMENTADOR"
                                                       Style="{StaticResource ReadKey}"
                                                       TextColor="#0369A1" />
                                                <Label Text="{Binding Alimentador}"
                                                       FontSize="12"
                                                       FontAttributes="Bold"
                                                       TextColor="#0C4A6E" />
                                            </VerticalStackLayout>
                                        </Frame>

                                        <!-- [1,0] Fecha Denuncia -->
                                        <Frame Grid.Row="1" Grid.Column="0"
                                               Padding="10,8"
                                               Margin="0,0,4,8"
                                               CornerRadius="10"
                                               BackgroundColor="#FEFCE8"
                                               BorderColor="#FDE047"
                                               HasShadow="False">
                                            <VerticalStackLayout Spacing="3">
                                                <Label Text="🕐 FECHA DENUNCIA"
                                                       Style="{StaticResource ReadKey}"
                                                       TextColor="#A16207" />
                                                <Label Text="{Binding FechaDenuncia, StringFormat='{0:dd/MM/yyyy HH:mm}'}"
                                                       FontSize="11"
                                                       FontAttributes="Bold"
                                                       TextColor="#713F12" />
                                            </VerticalStackLayout>
                                        </Frame>

                                        <!-- [1,1] Tipificación -->
                                        <Frame Grid.Row="1" Grid.Column="1"
                                               Padding="10,8"
                                               Margin="4,0,0,8"
                                               CornerRadius="10"
                                               BackgroundColor="#FDF4FF"
                                               BorderColor="#E9D5FF"
                                               HasShadow="False">
                                            <VerticalStackLayout Spacing="3">
                                                <Label Text="🏷️ TIPIFICACIÓN"
                                                       Style="{StaticResource ReadKey}"
                                                       TextColor="#7E22CE" />
                                                <Label Text="{Binding TipificacionCompleta}"
                                                       FontSize="11"
                                                       FontAttributes="Bold"
                                                       TextColor="#581C87"
                                                       LineBreakMode="TailTruncation"
                                                       MaxLines="2" />
                                            </VerticalStackLayout>
                                        </Frame>

                                    </Grid>

                                    <!-- Divisor antes de botones -->
                                    <BoxView HeightRequest="1"
                                             BackgroundColor="#F3F4F6"
                                             Margin="14,0" />

                                    <!-- ── BOTONES DE ACCIÓN ── -->
                                    <Grid ColumnDefinitions="*,*"
                                          ColumnSpacing="10"
                                          Padding="14,10,14,14">

                                        <Button Grid.Column="0"
                                                Text="🗺️  Ver Ruta"
                                                FontSize="13"
                                                FontAttributes="Bold"
                                                TextColor="#4F46E5"
                                                BackgroundColor="#EEF2FF"
                                                CornerRadius="10"
                                                HeightRequest="40"
                                                Clicked="OnRutaClicked" />

                                        <Button Grid.Column="1"
                                                Text="▶  Ejecutar"
                                                FontSize="13"
                                                FontAttributes="Bold"
                                                TextColor="White"
                                                BackgroundColor="#166534"
                                                CornerRadius="10"
                                                HeightRequest="40"
                                                Clicked="OnEjecutarClicked" />

                                    </Grid>

                                </VerticalStackLayout>
                            </Frame>

                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>

    </Grid>
</ContentPage>
