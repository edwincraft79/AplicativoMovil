<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AplicacionMovil.Modules.Deficiencias.Pages.RegistroInspeccionDefPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title=""
    BackgroundColor="#F0FDFA">

    <ContentPage.Resources>

        <Style TargetType="Label" x:Key="SectionTitle">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="TextColor" Value="#0F766E" />
            <Setter Property="CharacterSpacing" Value="0.3" />
        </Style>

        <Style TargetType="Label" x:Key="FieldLabel">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="TextColor" Value="#374151" />
            <Setter Property="Margin" Value="2,0,0,4" />
        </Style>

        <Style TargetType="Frame" x:Key="InputBox">
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="BorderColor" Value="#99F6E4" />
            <Setter Property="BackgroundColor" Value="White" />
            <Setter Property="HasShadow" Value="False" />
        </Style>

        <Style TargetType="Frame" x:Key="EditCard">
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,14" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="HasShadow" Value="True" />
            <Setter Property="BorderColor" Value="Transparent" />
            <Setter Property="BackgroundColor" Value="White" />
        </Style>

    </ContentPage.Resources>

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsEnabled="False" IsVisible="False" />
    </Shell.BackButtonBehavior>

    <Grid RowDefinitions="Auto,*">

        <!-- ══════════════════════════════════════
             HEADER TEAL
        ══════════════════════════════════════ -->
        <Frame Grid.Row="0"
               Padding="0"
               CornerRadius="22"
               BorderColor="Transparent"
               HasShadow="True"
               BackgroundColor="#0F766E">

            <Grid RowDefinitions="Auto,Auto" Padding="16,14,16,18" RowSpacing="6">

                <Grid Grid.Row="0" ColumnDefinitions="Auto,*">
                    <Button Grid.Column="0"
                            Text="← Volver"
                            FontSize="12"
                            FontAttributes="Bold"
                            TextColor="White"
                            BackgroundColor="#0D9488"
                            CornerRadius="10"
                            Padding="12,6"
                            HeightRequest="36"
                            Clicked="OnBackClicked" />

                    <VerticalStackLayout Grid.Column="1"
                                         HorizontalOptions="End"
                                         VerticalOptions="Center"
                                         Spacing="1">
                        <Label Text="IDENTIFICACIÓN DE DEFICIENCIAS"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="End" />
                        <Label Text="Registro de inspección en campo"
                               FontSize="10"
                               TextColor="#99F6E4"
                               HorizontalOptions="End" />
                    </VerticalStackLayout>
                </Grid>

                <BoxView Grid.Row="1"
                         BackgroundColor="#14B8A6"
                         HeightRequest="2"
                         CornerRadius="1"
                         Opacity="0.5" />
            </Grid>
        </Frame>

        <!-- ══════════════════════════════════════
             CONTENIDO
        ══════════════════════════════════════ -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="14,16,14,28" Spacing="0">

                <!-- ══ Separador visual ══ -->
                <Grid ColumnDefinitions="*,Auto,*" Margin="0,0,0,16" ColumnSpacing="10">
                    <BoxView Grid.Column="0" HeightRequest="1" BackgroundColor="#99F6E4" VerticalOptions="Center" />
                    <Label Grid.Column="1"
                           Text="DATOS DE INSPECCIÓN"
                           FontSize="10"
                           FontAttributes="Bold"
                           TextColor="#0F766E"
                           CharacterSpacing="1"
                           VerticalOptions="Center" />
                    <BoxView Grid.Column="2" HeightRequest="1" BackgroundColor="#99F6E4" VerticalOptions="Center" />
                </Grid>

                <!-- ┌──────────────────────┐
                     │  DATOS GENERALES     │
                     └──────────────────────┘ -->
                <Frame Style="{StaticResource EditCard}">
                    <VerticalStackLayout Spacing="12">

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                            <Frame Grid.Column="0"
                                   Padding="6"
                                   CornerRadius="8"
                                   BackgroundColor="#CCFBF1"
                                   BorderColor="Transparent"
                                   HasShadow="False">
                                <Label Text="📋" FontSize="14" />
                            </Frame>
                            <Label Grid.Column="1"
                                   Text="Datos Generales"
                                   Style="{StaticResource SectionTitle}"
                                   VerticalOptions="Center" />
                        </Grid>

                        <!-- Unidad Zonal -->
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Unidad Zonal *" Style="{StaticResource FieldLabel}" />
                            <Frame Style="{StaticResource InputBox}">
                                <Picker x:Name="pickerUnidadZonal"
                                        BackgroundColor="Transparent"
                                        FontSize="14"
                                        TextColor="#111827"
                                        SelectedIndexChanged="OnUnidadZonalChanged">
                                    <Picker.Items>
                                        <x:String>Ananea</x:String>
                                        <x:String>Antauta</x:String>
                                        <x:String>Ayaviri</x:String>
                                        <x:String>Azangaro</x:String>
                                        <x:String>Desaguadero</x:String>
                                        <x:String>Huancane</x:String>
                                        <x:String>Ilave</x:String>
                                        <x:String>Juli</x:String>
                                        <x:String>Juliaca</x:String>
                                        <x:String>Lampa</x:String>
                                        <x:String>Moho</x:String>
                                        <x:String>Puno</x:String>
                                        <x:String>Putina</x:String>
                                        <x:String>San Gaban</x:String>
                                        <x:String>Sandia</x:String>
                                        <x:String>Yunguyo</x:String>
                                    </Picker.Items>
                                </Picker>
                            </Frame>
                        </VerticalStackLayout>

                        <!-- Cód. Denunciante + Tipo Instalación -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label Text="Cód. Denunciante *" Style="{StaticResource FieldLabel}" />
                                <Frame Style="{StaticResource InputBox}">
                                    <Picker x:Name="pickerCodigoDenunciante"
                                            BackgroundColor="Transparent"
                                            FontSize="13"
                                            TextColor="#111827"
                                            SelectedIndex="0">
                                        <Picker.Items>
                                            <x:String>1: Concesionaria</x:String>
                                            <x:String>2: Usuario</x:String>
                                            <x:String>3: Autoridades</x:String>
                                            <x:String>4: OSINERGMIN</x:String>
                                        </Picker.Items>
                                    </Picker>
                                </Frame>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="Nivel de Tensión *" Style="{StaticResource FieldLabel}" />
                                <Frame Style="{StaticResource InputBox}">
                                    <Picker x:Name="pickerNivelTension"
                                            Title="Seleccione"
                                            BackgroundColor="Transparent"
                                            FontSize="13"
                                            TextColor="#111827">
                                        <Picker.Items>
                                            <x:String>Baja Tension</x:String>
                                            <x:String>Media Tension</x:String>
                                            <x:String>Alta Tension</x:String>
                                        </Picker.Items>
                                    </Picker>
                                </Frame>
                            </VerticalStackLayout>
                        </Grid>

                    </VerticalStackLayout>
                </Frame>

                <!-- ┌──────────────────────┐
                     │  OBSERVACIONES       │
                     └──────────────────────┘ -->
                <Frame Style="{StaticResource EditCard}">
                    <VerticalStackLayout Spacing="12">

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                            <Frame Grid.Column="0"
                                   Padding="6"
                                   CornerRadius="8"
                                   BackgroundColor="#CCFBF1"
                                   BorderColor="Transparent"
                                   HasShadow="False">
                                <Label Text="📝" FontSize="14" />
                            </Frame>
                            <Label Grid.Column="1"
                                   Text="Observaciones"
                                   Style="{StaticResource SectionTitle}"
                                   VerticalOptions="Center" />
                        </Grid>

                        <Frame Padding="12"
                               CornerRadius="10"
                               BorderColor="#99F6E4"
                               BackgroundColor="#F0FDFA"
                               HasShadow="False">
                            <Editor x:Name="txtObservaciones"
                                    Placeholder="Describa las observaciones de la inspección..."
                                    PlaceholderColor="#5EEAD4"
                                    AutoSize="TextChanges"
                                    MinimumHeightRequest="100"
                                    BackgroundColor="Transparent"
                                    FontSize="14"
                                    TextColor="#111827" />
                        </Frame>

                    </VerticalStackLayout>
                </Frame>

                <!-- ┌──────────────────────┐
                     │  UBICACIÓN GPS       │
                     └──────────────────────┘ -->
                <Frame Style="{StaticResource EditCard}">
                    <VerticalStackLayout Spacing="12">

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                            <Frame Grid.Column="0"
                                   Padding="6"
                                   CornerRadius="8"
                                   BackgroundColor="#DBEAFE"
                                   BorderColor="Transparent"
                                   HasShadow="False">
                                <Label Text="🌍" FontSize="14" />
                            </Frame>
                            <Label Grid.Column="1"
                                   Text="Ubicación GPS"
                                   Style="{StaticResource SectionTitle}"
                                   VerticalOptions="Center" />
                        </Grid>

                        <Frame Padding="12,10"
                               CornerRadius="10"
                               BorderColor="#BFDBFE"
                               BackgroundColor="#EFF6FF"
                               HasShadow="False">
                            <Grid ColumnDefinitions="*,Auto">
                                <VerticalStackLayout Grid.Column="0" Spacing="3">
                                    <Label x:Name="lblPrecision"
                                           Text="📏 Precisión: --"
                                           TextColor="#1E40AF"
                                           FontAttributes="Bold"
                                           FontSize="13" />
                                    <Label Text="🎯 Objetivo: hasta 30 metros"
                                           TextColor="#3B82F6"
                                           FontSize="11" />
                                </VerticalStackLayout>
                                <Label Grid.Column="1"
                                       Text="GPS"
                                       FontSize="22"
                                       TextColor="#BFDBFE"
                                       VerticalOptions="Center" />
                            </Grid>
                        </Frame>

                        <Button x:Name="btnGps"
                                Text="📍  Obtener GPS"
                                BackgroundColor="#0284C7"
                                TextColor="White"
                                CornerRadius="12"
                                HeightRequest="46"
                                FontAttributes="Bold"
                                FontSize="14"
                                Clicked="OnGpsClicked" />

                        <Frame Padding="12,10"
                               CornerRadius="10"
                               BorderColor="#99F6E4"
                               BackgroundColor="#F0FDFA"
                               HasShadow="False">
                            <Label x:Name="lblGps"
                                   Text="📌 Sin GPS registrado"
                                   TextColor="#0F766E"
                                   FontAttributes="Italic"
                                   FontSize="12" />
                        </Frame>

                    </VerticalStackLayout>
                </Frame>

                <!-- ┌──────────────────────┐
                     │  FOTO DE CAMPO       │
                     └──────────────────────┘ -->
                <Frame Style="{StaticResource EditCard}">
                    <VerticalStackLayout Spacing="12">

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                            <Frame Grid.Column="0"
                                   Padding="6"
                                   CornerRadius="8"
                                   BackgroundColor="#EDE9FE"
                                   BorderColor="Transparent"
                                   HasShadow="False">
                                <Label Text="📷" FontSize="14" />
                            </Frame>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                                <Label Text="Foto de Campo"
                                       Style="{StaticResource SectionTitle}" />
                                <Label Text="Opcional"
                                       FontSize="10"
                                       TextColor="#9CA3AF" />
                            </VerticalStackLayout>
                        </Grid>

                        <Button Text="📸  Tomar Foto"
                                BackgroundColor="#7C3AED"
                                TextColor="White"
                                CornerRadius="12"
                                HeightRequest="46"
                                FontAttributes="Bold"
                                FontSize="14"
                                Clicked="OnTomarFotoClicked" />

                        <!-- ✅ Image sin Frame wrapper — evita bloqueo de render en Android -->
                        <Image x:Name="imgPreview"
                               HeightRequest="240"
                               WidthRequest="300"
                               Aspect="AspectFit"
                               HorizontalOptions="Center"
                               IsVisible="False"
                               BackgroundColor="#F5F3FF" />

                        <Label x:Name="lblFotoInfo"
                               Text="📁 Sin foto adjunta"
                               TextColor="#9CA3AF"
                               FontAttributes="Italic"
                               FontSize="12"
                               HorizontalOptions="Center" />

                    </VerticalStackLayout>
                </Frame>

                <!-- ══════════════════════════════
                     BOTONES FINALES
                ══════════════════════════════ -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,6,0,0">
                    <Button Grid.Column="0"
                            Text="✓  Enviar"
                            BackgroundColor="#0F766E"
                            TextColor="White"
                            FontAttributes="Bold"
                            FontSize="15"
                            CornerRadius="14"
                            HeightRequest="52"
                            Clicked="OnEnviarClicked" />

                    <Button Grid.Column="1"
                            Text="💾  Offline"
                            BackgroundColor="#0D9488"
                            TextColor="White"
                            FontAttributes="Bold"
                            FontSize="15"
                            CornerRadius="14"
                            HeightRequest="52"
                            Clicked="OnGuardarOfflineClicked" />
                </Grid>

                <Button Text="📋  Ver Historial Local"
                        BackgroundColor="#6D28D9"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontSize="14"
                        CornerRadius="14"
                        HeightRequest="48"
                        Margin="0,10,0,0"
                        Clicked="OnHistorialClicked" />

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
