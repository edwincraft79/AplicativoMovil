<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="AplicacionMovil.Pages.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Iniciar sesión"
    BackgroundColor="#F8FAFC">

    <ContentPage.Resources>
        <!-- Estilos mejorados -->
        <Style TargetType="Label" x:Key="TitleLabel">
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="TextColor" Value="#0F172A" />
        </Style>

        <Style TargetType="Label" x:Key="SubtitleLabel">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="TextColor" Value="#64748B" />
        </Style>

        <Style TargetType="Label" x:Key="FieldLabel">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="TextColor" Value="#475569" />
        </Style>

        <Style TargetType="Entry">
            <Setter Property="BackgroundColor" Value="Transparent" />
            <Setter Property="TextColor" Value="#0F172A" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="HeightRequest" Value="48" />
        </Style>

        <Style TargetType="Picker">
            <Setter Property="BackgroundColor" Value="Transparent" />
            <Setter Property="TextColor" Value="#0F172A" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="HeightRequest" Value="48" />
        </Style>

        <Style TargetType="Button" x:Key="PrimaryButton">
            <Setter Property="BackgroundColor" Value="#3B82F6" />
            <Setter Property="TextColor" Value="White" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="HeightRequest" Value="52" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="FontSize" Value="16" />
        </Style>
    </ContentPage.Resources>

    <Grid>
        <ScrollView>
            <VerticalStackLayout
                Padding="24,32,24,24"
                Spacing="0">

                <!-- Logo de la empresa -->
                <Image
                    Source="logo_empresa.png"
                    WidthRequest="100"
                    HeightRequest="100"
                    HorizontalOptions="Center"
                    Margin="0,0,0,24" />

                <!-- Título -->
                <Label
                    Text="Bienvenido"
                    Style="{StaticResource TitleLabel}"
                    HorizontalOptions="Center"
                    Margin="0,0,0,8" />

                <Label
                    Text="Ingresa tus credenciales para continuar"
                    Style="{StaticResource SubtitleLabel}"
                    HorizontalOptions="Center"
                    Margin="0,0,0,32" />

                <!-- Tarjeta principal de login -->
                <Frame
                    Padding="0"
                    BackgroundColor="White"
                    BorderColor="Transparent"
                    CornerRadius="20"
                    HasShadow="True"
                    Margin="0,0,0,20">

                    <VerticalStackLayout Padding="24" Spacing="20">

                        <!-- Usuario (Cliente) con autocomplete -->
                        <VerticalStackLayout Spacing="8">
                            <Label
                                Text="Usuario (Cliente)"
                                Style="{StaticResource FieldLabel}" />

                            <Frame
                                Padding="0"
                                CornerRadius="12"
                                BorderColor="#E2E8F0"
                                BackgroundColor="#F8FAFC"
                                HasShadow="False">

                                <Grid RowDefinitions="Auto,Auto" Padding="16,0">

                                    <!-- Entry principal -->
                                    <Entry
                                        x:Name="txtOperador"
                                        Grid.Row="0"
                                        Placeholder="Ej: ecoarite"
                                        PlaceholderColor="#94A3B8"
                                        TextChanged="OnOperadorTextChanged"
                                        Completed="OnOperadorCompleted" />

                                    <!-- Panel de sugerencias -->
                                    <Border
                                        x:Name="panelOperadores"
                                        Grid.Row="1"
                                        Stroke="#E2E8F0"
                                        StrokeThickness="1"
                                        BackgroundColor="White"
                                        StrokeShape="RoundRectangle 8"
                                        IsVisible="False"
                                        Margin="0,12,0,0">

                                        <CollectionView
                                            x:Name="cvOperadores"
                                            SelectionMode="Single"
                                            SelectionChanged="OnOperadorSelected"
                                            MaximumHeightRequest="180">

                                            <CollectionView.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Padding="14,12">
                                                        <Label
                                                            Text="{Binding Usuario}"
                                                            FontSize="15"
                                                            TextColor="#0F172A" />
                                                    </Grid>
                                                </DataTemplate>
                                            </CollectionView.ItemTemplate>
                                        </CollectionView>
                                    </Border>
                                </Grid>
                            </Frame>
                        </VerticalStackLayout>

                        <!-- Equipo móvil -->
                        <VerticalStackLayout Spacing="8">
                            <Label
                                Text="Equipo móvil"
                                Style="{StaticResource FieldLabel}" />

                            <Frame
                                Padding="16,0"
                                CornerRadius="12"
                                BorderColor="#E2E8F0"
                                BackgroundColor="#F8FAFC"
                                HasShadow="False">

                                <Picker
                                    x:Name="pkMovil"
                                    Title="Seleccione su equipo"
                                    TitleColor="#94A3B8" />
                            </Frame>
                        </VerticalStackLayout>

                        <!-- Contraseña con botón de mostrar/ocultar -->
                        <VerticalStackLayout Spacing="8">
                            <Label
                                Text="Contraseña"
                                Style="{StaticResource FieldLabel}" />

                            <Frame
                                Padding="16,0,8,0"
                                CornerRadius="12"
                                BorderColor="#E2E8F0"
                                BackgroundColor="#F8FAFC"
                                HasShadow="False">

                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="4">

                                    <!-- Entry de contraseña -->
                                    <Entry
                                        x:Name="txtPassword"
                                        Grid.Column="0"
                                        Placeholder="Ingrese su contraseña"
                                        PlaceholderColor="#94A3B8"
                                        IsPassword="True" />

                                    <!-- Botón ojo para mostrar/ocultar -->
                                    <Button
                                        x:Name="btnTogglePassword"
                                        Grid.Column="1"
                                        Text="👁️"
                                        BackgroundColor="Transparent"
                                        TextColor="#64748B"
                                        FontSize="20"
                                        WidthRequest="44"
                                        HeightRequest="44"
                                        CornerRadius="8"
                                        Clicked="OnTogglePasswordClicked" />
                                </Grid>
                            </Frame>
                        </VerticalStackLayout>

                        <!-- Botón Ingresar -->
                        <Button
                            Text="Ingresar"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,12,0,0"
                            Clicked="OnLoginClicked">
                            <Button.Shadow>
                                <Shadow
                                    Brush="#3B82F6"
                                    Offset="0,4"
                                    Radius="12"
                                    Opacity="0.3" />
                            </Button.Shadow>
                        </Button>

                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Indicador de carga (overlay) -->
        <Grid
            x:Name="loadingOverlay"
            IsVisible="False"
            BackgroundColor="#80000000">

            <VerticalStackLayout
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Spacing="16">

                <ActivityIndicator
                    IsRunning="True"
                    Color="White"
                    WidthRequest="48"
                    HeightRequest="48" />

                <Label
                    Text="Verificando credenciales..."
                    TextColor="White"
                    FontSize="15"
                    FontAttributes="Bold" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
